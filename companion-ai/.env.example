# =============================================================================
# Companion AI — Environment Configuration
# =============================================================================
#
# Copy this file to ``.env`` in this directory (same folder as ``main.py``) to
# apply defaults without exporting variables in every shell. Paths are resolved
# from that directory. Git ignores ``.env``; only ``.env.example`` is tracked.

# ------------------------------------------------------------------
# Lite Mode (no Docker — SQLite + in-process fallbacks)
# ------------------------------------------------------------------
# Required on Cloud Agent VMs and any host without PostgreSQL/Redis, or the
# reminder scheduler and memory layer will try ``localhost`` sockets and log
# connection errors. ``python scripts/start_lite_server.py`` sets the first line
# before import; for ``uvicorn main:app`` you still need these in env or here.
COMPANION_LITE_MODE=true
COMPANION_ENABLE_VOICE=false
COMPANION_ENABLE_ACTION_2D=false
COMPANION_ENABLE_DEVICE_COORDINATION=false
# Optional: quieter cold start (default is true)
# COMPANION_ENABLE_MEMORY_PIPELINE=false

# ------------------------------------------------------------------
# LLM Providers (cloud API only)
# ------------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ------------------------------------------------------------------
# Voice (cloud API)
# ------------------------------------------------------------------
WHISPER_API_KEY=...
TTS_API_KEY=...

# ------------------------------------------------------------------
# Action / 2D Generation
# ------------------------------------------------------------------
ACTION_API_KEY=...

# ------------------------------------------------------------------
# Security
# ------------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-string
ENCRYPTION_KEY=...

# ------------------------------------------------------------------
# Optional: override defaults
# ------------------------------------------------------------------
# COMPANION_DEFAULT_LLM_MODEL=gpt-4o
# COMPANION_TTS_PROVIDER=fish_audio
# COMPANION_ACTION_PROVIDER=tongyi
#
# Working memory — optional LLM (extra API calls when enabled; TTL cache per session)
# COMPANION_WORKING_MEMORY_LLM_SUMMARY=true
# COMPANION_WORKING_MEMORY_LLM_DIGEST=true
# COMPANION_WORKING_MEMORY_SUMMARY_MODEL=gpt-4o-mini
# COMPANION_WORKING_MEMORY_SUMMARY_TTL_SECONDS=45
