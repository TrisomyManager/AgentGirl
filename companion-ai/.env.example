# ------------------------------------------------------------------
# LLM Providers (cloud API only)
# ------------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ------------------------------------------------------------------
# Voice (cloud API)
# ------------------------------------------------------------------
